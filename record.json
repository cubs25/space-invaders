css
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #000;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-family: "Berkeley Mono", Monaco, monospace;
  color: #fff;
}

#game {
  position: relative;
  width: 600px;
  height: 700px;
  background: #050510;
  border: 1px solid #1a1a4a;
  overflow: hidden;
}

#hud {
  display: flex;
  justify-content: space-between;
  padding: 10px 20px;
  background: #0a0a2a;
  border-bottom: 1px solid #1a1a4a;
  font-size: 14px;
  letter-spacing: 2px;
}

#board {
  position: relative;
  width: 100%;
  height: calc(100% - 41px);
}

#player {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28px;
  transition: left 0.05s;
}

/* Enemigos */
.enemy {
  position: absolute;
  font-size: 24px;
  transition: left 0.1s;
  animation: pulse 1s infinite alternate;
}

.enemy-1 { color: #00ff88; }
.enemy-2 { color: #00cfff; }
.enemy-3 { color: #ff8800; }
.enemy-4 { color: #ff2244; }

@keyframes pulse {
  from { transform: scale(1); }
  to   { transform: scale(1.15); }
}

/* Balas */
.bullet {
  position: absolute;
  width: 3px;
  height: 16px;
  background: #fff;
  border-radius: 2px;
}

.bullet-enemy {
  background: #ff2244;
}

/* Pantallas */
.screen {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: rgba(0, 0, 0, 0.85);
  gap: 16px;
  z-index: 10;
}

.screen h1 {
  font-size: 36px;
  letter-spacing: 6px;
  color: #00ff88;
}

.screen p {
  font-size: 14px;
  letter-spacing: 2px;
  color: #aaa;
}

.hidden {
  display: none;
}
