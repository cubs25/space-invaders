css
@import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #000;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-family: 'VT323', monospace;
  color: #fff;
  transform: scale(0.85);
  transform-origin: center center;
}

#game {
  position: relative;
  width: 620px;
  height: 740px;
  background: #050510;
  border: 1px solid #1a1a4a;
  overflow: hidden;
}

/* Marca de agua */
#watermark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 340px;
  height: 340px;
  opacity: 0.04;
  pointer-events: none;
  z-index: 0;
}

#watermark svg {
  width: 100%;
  height: 100%;
  fill: #ffffff;
}

/* HUD */
#hud {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 16px;
  background: #0a0a2a;
  border-bottom: 1px solid #1a1a4a;
  font-size: 20px;
  letter-spacing: 2px;
}

/* Board */
#board {
  position: relative;
  width: 100%;
  height: calc(100% - 82px);
  z-index: 1;
}

/* Bottom bar score */
#bottom-bar {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 6px;
  background: #0a0a2a;
  border-top: 1px solid #1a1a4a;
  font-size: 28px;
  letter-spacing: 4px;
  color: #ef4343;
}

/* Player */
#player {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28px;
  transition: left 0.05s;
  z-index: 2;
}

/* Enemigos */
.enemy {
  position: absolute;
  width: 36px;
  height: 36px;
  z-index: 2;
}

/* Balas */
.bullet {
  position: absolute;
  width: 3px;
  height: 16px;
  background: #fff;
  border-radius: 2px;
  z-index: 2;
}

.bullet-enemy {
  background: #ef4343;
}

/* Pantallas */
.screen {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: rgba(0, 0, 0, 0.85);
  gap: 16px;
  z-index: 10;
}

.screen h1 {
  font-size: 48px;
  letter-spacing: 6px;
  color: #ef4343;
}

.screen p {
  font-size: 22px;
  letter-spacing: 2px;
  color: #aaa;
}

.hidden { display: none; }

/* Vida icons */
.life-icon {
  font-size: 14px;
  margin-left: 3px;
}

/* Destello píxeles */
@keyframes pixelFly {
  0%   { transform: translate(0, 0); opacity: 1; }
  100% { transform: translate(var(--dx), var(--dy)); opacity: 0; }
}

/* Puntos bonus flotantes */
@keyframes floatUp {
  0%   { transform: translateY(0); opacity: 1; }
  100% { transform: translateY(-30px); opacity: 0; }
}

/* Nave bonus */
#bonus-ship {
  filter: drop-shadow(0 0 4px #ff8800);
}
Ahora agrega los sonidos al main.js. Busca la función pixelFlash y justo antes de ella pega esto:

js
// --- Sonidos con Web Audio API ---
const AudioCtx = window.AudioContext || window.webkitAudioContext;
let audioCtx;

function getAudio() {
  if (!audioCtx) audioCtx = new AudioCtx();
  return audioCtx;
}

function playShoot() {
  const ctx = getAudio();
  const o = ctx.createOscillator();
  const g = ctx.createGain();
  o.connect(g); g.connect(ctx.destination);
  o.type = 'square';
  o.frequency.setValueAtTime(880, ctx.currentTime);
  o.frequency.exponentialRampToValueAtTime(110, ctx.currentTime + 0.12);
  g.gain.setValueAtTime(0.15, ctx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.12);
  o.start(); o.stop(ctx.currentTime + 0.12);
}

function playEnemyHit() {
  const ctx = getAudio();
  const o = ctx.createOscillator();
  const g = ctx.createGain();
  o.connect(g); g.connect(ctx.destination);
  o.type = 'sawtooth';
  o.frequency.setValueAtTime(220, ctx.currentTime);
  o.frequency.exponentialRampToValueAtTime(40, ctx.currentTime + 0.2);
  g.gain.setValueAtTime(0.2, ctx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.2);
  o.start(); o.stop(ctx.currentTime + 0.2);
}

function playPlayerHit() {
  const ctx = getAudio();
  for (let i = 0; i < 3; i++) {
    const o = ctx.createOscillator();
    const g = ctx.createGain();
    o.connect(g); g.connect(ctx.destination);
    o.type = 'square';
    o.frequency.setValueAtTime(150 - i * 40, ctx.currentTime + i * 0.08);
    g.gain.setValueAtTime(0.2, ctx.currentTime + i * 0.08);
    g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.08 + 0.1);
    o.start(ctx.currentTime + i * 0.08);
    o.stop(ctx.currentTime + i * 0.08 + 0.1);
  }
}

function playBonus() {
  const ctx = getAudio();
  const o = ctx.createOscillator();
  const g = ctx.createGain();
  o.connect(g); g.connect(ctx.destination);
  o.type = 'sine';
  o.frequency.setValueAtTime(440, ctx.currentTime);
  o.frequency.setValueAtTime(660, ctx.currentTime + 0.08);
  o.frequency.setValueAtTime(880, ctx.currentTime + 0.16);
  g.gain.setValueAtTime(0.15, ctx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
  o.start(); o.stop(ctx.currentTime + 0.3);
}
