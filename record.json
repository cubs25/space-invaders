Perfecto, la base está funcionando.

Ahora reemplaza todo el contenido de main.js con esto — aquí va el jugador completo: se mueve con las flechas y dispara con la barra espaciadora:

js
// --- Estado del juego ---
const state = {
  playerX: 270,
  bullets: [],
  enemies: [],
  score: 0,
  lives: 3,
  level: 1,
  running: false,
  keys: {},
};

// --- Referencias DOM ---
const board = document.getElementById('board');
const player = document.getElementById('player');
const scoreEl = document.getElementById('score');
const livesEl = document.getElementById('lives');
const levelEl = document.getElementById('level');
const screenStart = document.getElementById('screen-start');
const screenGameOver = document.getElementById('screen-gameover');

// --- Input ---
document.addEventListener('keydown', (e) => {
  state.keys[e.code] = true;

  if (e.code === 'Enter') {
    if (!state.running) startGame();
  }

  if (e.code === 'Space' && state.running) {
    e.preventDefault();
    shootPlayer();
  }
});

document.addEventListener('keyup', (e) => {
  state.keys[e.code] = false;
});

// --- Iniciar juego ---
function startGame() {
  state.running = true;
  state.score = 0;
  state.lives = 3;
  state.level = 1;
  state.playerX = 270;
  state.bullets = [];

  screenStart.classList.add('hidden');
  screenGameOver.classList.add('hidden');

  updateHUD();
  gameLoop();
}

// --- HUD ---
function updateHUD() {
  scoreEl.textContent = state.score;
  livesEl.textContent = state.lives;
  levelEl.textContent = state.level;
}

// --- Mover jugador ---
function movePlayer() {
  if (state.keys['ArrowLeft'] && state.playerX > 10) {
    state.playerX -= 5;
  }
  if (state.keys['ArrowRight'] && state.playerX < 555) {
    state.playerX += 5;
  }
  player.style.left = state.playerX + 'px';
}

// --- Disparar jugador ---
let lastShot = 0;
function shootPlayer() {
  const now = Date.now();
  if (now - lastShot < 400) return; // máximo 1 bala cada 400ms
  lastShot = now;

  const bullet = document.createElement('div');
  bullet.classList.add('bullet');
  bullet.style.left = (state.playerX + 12) + 'px';
  bullet.style.bottom = '55px';
  board.appendChild(bullet);

  state.bullets.push({ el: bullet, x: state.playerX + 12, y: 55, owner: 'player' });
}

// --- Mover balas ---
function moveBullets() {
  state.bullets = state.bullets.filter(b => {
    if (b.owner === 'player') {
      b.y += 10;
      b.el.style.bottom = b.y + 'px';
      if (b.y > 650) {
        b.el.remove();
        return false;
      }
    }
    return true;
  });
}

// --- Game Loop ---
function gameLoop() {
  if (!state.running) return;

  movePlayer();
  moveBullets();
  updateHUD();

  requestAnimationFrame(gameLoop);
}
